---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const articles = await getCollection('news');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { title, pubDate, description, category, heroImage, sentiment, sourceUrl, tags } = article.data;

const readingTime = getReadingTime(article.body ?? '');

// Related articles: same category, excluding current, sorted by tag overlap then date
const allArticles = await getCollection('news');
const currentTags = new Set(tags ?? []);
const related = allArticles
  .filter(a => a.id !== article.id && a.data.category === category)
  .map(a => {
    const overlap = (a.data.tags ?? []).filter(t => currentTags.has(t)).length;
    return { article: a, overlap };
  })
  .sort((a, b) => b.overlap - a.overlap || b.article.data.pubDate.getTime() - a.article.data.pubDate.getTime())
  .slice(0, 3);
---

<ArticleLayout
  title={title}
  description={description}
  pubDate={pubDate}
  country=""
  countryCode=""
  category={category}
  heroImage={heroImage}
  sentiment={sentiment}
  sourceUrl={sourceUrl}
  readingTime={readingTime}
>
  <Content />
</ArticleLayout>

{related.length > 0 && (
  <section class="max-w-6xl mx-auto px-6 pb-16">
    <div class="flex items-center gap-4 mb-6">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--color-muted)]">Related stories</h2>
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {related.map(({ article: r }) => (
        <ArticleCard
          id={r.id}
          slug={r.id}
          readingTime={getReadingTime(r.body ?? '')}
          {...r.data}
        />
      ))}
    </div>
  </section>
)}
