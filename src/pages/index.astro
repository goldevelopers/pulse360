---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CategoryNav from '../components/CategoryNav.astro';
import { getReadingTime } from '../utils/readingTime';

const allArticles = await getCollection('news');

// Only show articles from the last 24 hours that the researcher selected
const MAX_AGE_MS = 24 * 60 * 60 * 1000;
const now = Date.now();

const sorted = allArticles
  .filter(a => {
    const order = a.data.displayOrder ?? 999;
    if (order >= 999) return false;
    // Exclude stale articles even if they still have a low displayOrder
    const age = now - a.data.pubDate.getTime();
    return age <= MAX_AGE_MS;
  })
  .sort((a, b) => {
    // Primary: displayOrder (lowest first — researcher ranks by
    // time-decayed importance, so fresher articles get lower values)
    const orderDiff = (a.data.displayOrder ?? 999) - (b.data.displayOrder ?? 999);
    if (orderDiff !== 0) return orderDiff;
    // Tiebreaker: newest first
    return b.data.pubDate.getTime() - a.data.pubDate.getTime();
  });
const latest = sorted.slice(0, 50);

// Category counts for the live ticker
const categoryCounts: Record<string, number> = {};
for (const a of allArticles) {
  const cat = a.data.category;
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
}
---

<BaseLayout title="Home" description="pulse360 — the world's simplest global news snapshot, refreshed every 4 hours.">

  <!-- Compact Hero -->
  <section class="hero-section max-w-6xl mx-auto px-6 pt-8 pb-6">
    <!-- Top row: headline + live pulse -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-5">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-[var(--color-ink)] leading-tight" style="font-family: var(--font-prose)">
          The world in a glance<span class="text-[var(--color-accent)]">.</span>
        </h1>
        <p class="text-sm text-[var(--color-muted)] mt-1.5">
          AI-synthesized from 195+ sources &middot; No ads &middot; No noise
        </p>
      </div>
      <div class="flex items-center gap-2 text-xs text-[var(--color-muted)] shrink-0">
        <span class="live-pulse relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--color-accent)] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-accent)]"></span>
        </span>
        <span class="tabular-nums">
          {allArticles.length} stories
        </span>
        <span class="opacity-40">&middot;</span>
        <span>Updated every 4h</span>
      </div>
    </div>

    <!-- Category nav chips -->
    <CategoryNav active={null} counts={categoryCounts} total={allArticles.length} />
  </section>

  <!-- Divider -->
  <section class="max-w-6xl mx-auto px-6 pb-4">
    <div class="flex items-center gap-4">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--color-muted)]">Right now</h2>
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      <span class="text-xs text-[var(--color-muted)] opacity-50 tabular-nums">{latest.length} stories</span>
    </div>
  </section>

  <!-- Articles grid -->
  <section class="max-w-6xl mx-auto px-6 pb-16">
    {latest.length === 0 ? (
      <div class="text-center py-24 text-[var(--color-muted)]">
        <p class="text-lg">Nothing yet.</p>
        <p class="text-sm mt-2 opacity-60">The researcher publishes every 4 hours.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {latest.map(article => (
          <ArticleCard id={article.id} slug={article.id} readingTime={getReadingTime(article.body ?? '')} {...article.data} />
        ))}
      </div>
    )}
  </section>

  <!-- Archive link -->
  <div class="reveal max-w-6xl mx-auto px-6 pb-20 text-center">
    <a
      href={`${import.meta.env.BASE_URL}archive`}
      class="group inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-full border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-ink)] hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-accent-soft)] transition-all duration-200"
    >
      Browse the archive
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
