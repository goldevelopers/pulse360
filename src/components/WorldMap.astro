---
/**
 * Interactive SVG world-map with real country outlines from Natural Earth data.
 * Each country highlights on hover and links to /country/<code>.
 * Countries with articles get an accent fill; others stay muted.
 */
import worldPaths from '../data/world-map-paths.json';

interface Props {
  /** Set of country codes that have at least one article */
  activeCodes?: Set<string>;
}

const { activeCodes = new Set() } = Astro.props;

// All country entries: [alpha2Code, svgPathData]
const allCountries = Object.entries(worldPaths as Record<string, string>);
---

<div class="world-map-container w-full overflow-x-auto">
  <svg
    viewBox="0 0 1000 500"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full max-w-4xl mx-auto"
    role="img"
    aria-label="World map showing countries with news coverage"
    preserveAspectRatio="xMidYMid meet"
  >
    <!-- Ocean background -->
    <rect width="1000" height="500" fill="var(--color-surface)" rx="8" />

    <!-- All countries -->
    {allCountries.map(([code, d]) => {
      const hasArticles = activeCodes.has(code);
      if (hasArticles) {
        return (
          <a href={`${import.meta.env.BASE_URL}country/${code}`} class="map-country active">
            <title>{code} — click to view articles</title>
            <path
              d={d}
              fill="var(--color-accent)"
              opacity="0.7"
              stroke="var(--color-accent)"
              stroke-width="0.8"
              stroke-linejoin="round"
              class="transition-all duration-200"
            />
          </a>
        );
      }
      return (
        <path
          d={d}
          fill="var(--color-border)"
          opacity="0.35"
          stroke="var(--color-muted)"
          stroke-width="0.3"
          stroke-linejoin="round"
        />
      );
    })}
  </svg>
</div>

<style>
  .map-country.active {
    cursor: pointer;
  }
  .map-country.active:hover path {
    opacity: 0.95 !important;
    fill: var(--color-accent);
    stroke: var(--color-accent);
    stroke-width: 1.5;
    filter: drop-shadow(0 0 4px var(--color-accent));
  }
  .map-country.active:focus-visible path {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
