---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const allArticles = await getCollection('news');
  const PAGE_SIZE = 50;
  const totalPages = Math.max(1, Math.ceil(allArticles.length / PAGE_SIZE));
  return Array.from({ length: totalPages }, (_, i) => ({ params: { page: String(i + 1) } }));
}

const { page } = Astro.params;
const PAGE_SIZE = 50;
const allArticles = await getCollection('news');
const sorted = allArticles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const totalPages = Math.max(1, Math.ceil(sorted.length / PAGE_SIZE));
const currentPage = Math.max(1, Math.min(Number(page), totalPages));
const start = (currentPage - 1) * PAGE_SIZE;
const end = start + PAGE_SIZE;
const pageArticles = sorted.slice(start, end);
---

<BaseLayout title={`Archive — Page ${currentPage}`} description={`pulse360 archive, page ${currentPage} of ${totalPages}.`}>
  <section class="max-w-6xl mx-auto px-6 pt-14 pb-6">
    <div class="flex items-center gap-4 mb-2">
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="inline-flex items-center gap-1 text-sm font-medium uppercase tracking-widest text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Feed
      </a>
      <div class="w-px h-4 bg-[var(--color-border)]"></div>
      <h1 class="text-xl sm:text-2xl font-bold text-[var(--color-ink)]" style="font-family: var(--font-prose)">
        Archive
      </h1>
    </div>
    <p class="text-sm text-[var(--color-muted)] mb-10 opacity-60">
      {sorted.length} article{sorted.length !== 1 ? 's' : ''} — page {currentPage} of {totalPages}
    </p>

    {pageArticles.length === 0 ? (
      <div class="text-center py-24 text-[var(--color-muted)]">
        <p>No articles yet. Check back soon.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="archive-grid">
        {pageArticles.map(article => (
          <ArticleCard id={article.id} slug={article.id} readingTime={getReadingTime(article.body ?? '')} {...article.data} />
        ))}
      </div>
    )}

    <!-- Pagination -->
    <div class="mt-14 flex justify-center gap-2">
      {currentPage > 1 && (
        <a href={`${import.meta.env.BASE_URL}archive/${currentPage - 1}`} class="px-4 py-2 rounded border text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-accent-soft)] transition-all">Prev</a>
      )}
      {Array.from({ length: totalPages }, (_, i) => (
        <a
          href={`${import.meta.env.BASE_URL}archive/${i + 1}`}
          class={`px-3 py-2 rounded text-sm font-medium ${i + 1 === currentPage ? 'bg-[var(--color-accent)] text-white' : 'text-[var(--color-muted)] hover:text-[var(--color-ink)] hover:bg-[var(--color-accent-soft)]'}`}
        >
          {i + 1}
        </a>
      ))}
      {currentPage < totalPages && (
        <a href={`${import.meta.env.BASE_URL}archive/${currentPage + 1}`} class="px-4 py-2 rounded border text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-accent-soft)] transition-all">Next</a>
      )}
    </div>
  </section>
</BaseLayout>
