---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const { title, description = 'pulse360 — Global news, synthesized by AI.', image, canonicalUrl } = Astro.props;
const resolvedImage = image ?? `${Astro.site}og-default.png`;
const canon = canonicalUrl ?? Astro.url.href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#6d8c5e" />
    <meta name="author" content="pulse360" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedImage} />
    <meta property="og:url" content={canon} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="pulse360" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedImage} />

    <link rel="canonical" href={canon} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="pulse360 RSS Feed" href="/rss.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;1,6..72,400&display=swap"
      rel="stylesheet"
    />

    <title>{title} — pulse360</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "pulse360",
      "url": "https://pulse360.news",
      "description": "AI-synthesized global news, refreshed every 4 hours. No ads, no noise.",
      "publisher": {
        "@type": "Organization",
        "name": "pulse360",
        "logo": { "@type": "ImageObject", "url": "https://pulse360.news/logo.png" }
      }
    })} />

    <!-- Dark mode: apply before paint to prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('pulse360_theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <!-- Service Worker registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>
    <slot name="head" />
  </head>
  <body>
    <!-- Accent line at very top -->
    <div class="accent-line"></div>

    <!-- Sticky header -->
    <header class="sticky top-0 z-50 backdrop-blur-xl bg-[var(--color-cream)]/85 border-b border-[var(--color-border)]">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-3 group shrink-0">
          <img
            src={`${import.meta.env.BASE_URL}logo.png`}
            alt="Pulse360"
            height="48"
            class="w-auto h-12 group-hover:scale-105 transition-transform duration-200 logo-adaptive"
          />
        </a>

        <!-- Desktop nav (hidden on mobile) -->
        <div class="hidden md:flex items-center gap-3">
          <a
            href={`${import.meta.env.BASE_URL}country`}
            class="text-sm tracking-wider uppercase text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors font-medium"
          >
            Countries
          </a>
          <div class="w-px h-4 bg-[var(--color-border)]"></div>
          <a
            href={`${import.meta.env.BASE_URL}archive`}
            class="text-sm tracking-wider uppercase text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors font-medium"
          >
            Archive
          </a>
          <div class="w-px h-4 bg-[var(--color-border)]"></div>
          <a
            href={`${import.meta.env.BASE_URL}bookmarks`}
            aria-label="Bookmarks"
            class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-[var(--color-accent-soft)] transition-all duration-200 text-[var(--color-muted)] hover:text-[var(--color-accent)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
          </a>
          <button
            id="search-toggle"
            aria-label="Search articles"
            class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-[var(--color-accent-soft)] transition-all duration-200 text-[var(--color-muted)] hover:text-[var(--color-accent)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
          <a
            href="/rss.xml"
            aria-label="RSS Feed"
            class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-[var(--color-accent-soft)] transition-all duration-200 text-[var(--color-muted)] hover:text-[var(--color-accent)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          </a>
          <div class="w-px h-4 bg-[var(--color-border)]"></div>
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-[var(--color-accent-soft)] transition-all duration-200 text-[var(--color-muted)] hover:text-[var(--color-accent)]"
          >
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
        </div>

        <!-- Mobile: search + hamburger (visible on mobile only) -->
        <div class="flex md:hidden items-center gap-2">
          <button
            id="search-toggle-mobile"
            aria-label="Search articles"
            class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-[var(--color-accent-soft)] transition-all duration-200 text-[var(--color-muted)] hover:text-[var(--color-accent)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
          <button
            id="drawer-open"
            aria-label="Open menu"
            class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-[var(--color-accent-soft)] transition-all duration-200 text-[var(--color-muted)] hover:text-[var(--color-accent)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile side drawer -->
    <div id="mobile-drawer-backdrop" class="fixed inset-0 z-[90] bg-black/40 backdrop-blur-sm hidden md:hidden" aria-hidden="true"></div>
    <aside
      id="mobile-drawer"
      class="fixed top-0 right-0 z-[95] h-full w-72 max-w-[80vw] bg-[var(--color-cream)] border-l border-[var(--color-border)] shadow-2xl translate-x-full transition-transform duration-300 ease-out md:hidden"
      aria-label="Mobile navigation"
    >
      <div class="flex items-center justify-between px-5 h-16 border-b border-[var(--color-border)]">
        <span class="text-sm font-semibold tracking-wider uppercase text-[var(--color-muted)]">Menu</span>
        <button
          id="drawer-close"
          aria-label="Close menu"
          class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-[var(--color-accent-soft)] transition-all duration-200 text-[var(--color-muted)] hover:text-[var(--color-accent)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <nav class="flex flex-col px-4 py-6 gap-1">
        <a
          href={`${import.meta.env.BASE_URL}country`}
          class="flex items-center gap-3 px-4 py-3 rounded-xl text-[var(--color-ink)] hover:bg-[var(--color-accent-soft)] transition-colors font-medium"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          Countries
        </a>
        <a
          href={`${import.meta.env.BASE_URL}archive`}
          class="flex items-center gap-3 px-4 py-3 rounded-xl text-[var(--color-ink)] hover:bg-[var(--color-accent-soft)] transition-colors font-medium"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 8-2-2H5L3 8"/><rect x="3" y="8" width="18" height="12" rx="1"/><path d="M10 12h4"/></svg>
          Archive
        </a>
        <a
          href={`${import.meta.env.BASE_URL}bookmarks`}
          class="flex items-center gap-3 px-4 py-3 rounded-xl text-[var(--color-ink)] hover:bg-[var(--color-accent-soft)] transition-colors font-medium"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
          Bookmarks
        </a>
        <a
          href="/rss.xml"
          class="flex items-center gap-3 px-4 py-3 rounded-xl text-[var(--color-ink)] hover:bg-[var(--color-accent-soft)] transition-colors font-medium"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          RSS Feed
        </a>
        <div class="my-3 mx-4 h-px bg-[var(--color-border)]"></div>
        <button
          id="theme-toggle-mobile"
          class="flex items-center gap-3 px-4 py-3 rounded-xl text-[var(--color-ink)] hover:bg-[var(--color-accent-soft)] transition-colors font-medium w-full text-left"
        >
          <svg id="icon-sun-mobile" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          <svg id="icon-moon-mobile" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          <span id="theme-label-mobile">Dark mode</span>
        </button>
      </nav>
    </aside>

    <main>
      <slot />
    </main>

    <footer class="mt-32">
      <div class="accent-line"></div>
      <div class="max-w-6xl mx-auto px-6 py-14 flex flex-col items-center gap-5 text-center">
        <img
          src={`${import.meta.env.BASE_URL}logo.png`}
          alt="Pulse360"
          height="36"
          class="w-auto h-9 opacity-60 logo-adaptive"
        />
        <p class="text-sm text-[var(--color-muted)] opacity-60">
          AI-synthesized global news &middot; Updated every 4 hours &middot; No ads, no noise
        </p>
      </div>
    </footer>

    <!-- Scroll to top button -->
    <button
      id="scroll-top"
      aria-label="Scroll to top"
      class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full bg-[var(--color-accent)] text-white shadow-lg flex items-center justify-center opacity-0 translate-y-4 pointer-events-none transition-all duration-300 hover:scale-110 hover:shadow-xl"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
    </button>

    <script>
      // Scroll to top
      const scrollBtn = document.getElementById('scroll-top');
      window.addEventListener('scroll', () => {
        if (!scrollBtn) return;
        if (window.scrollY > 400) {
          scrollBtn.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
          scrollBtn.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        } else {
          scrollBtn.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
          scrollBtn.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        }
      }, { passive: true });
      scrollBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>

    <script>
      // Mobile side drawer
      const drawer = document.getElementById('mobile-drawer')!;
      const drawerBackdrop = document.getElementById('mobile-drawer-backdrop')!;
      const drawerOpen = document.getElementById('drawer-open')!;
      const drawerClose = document.getElementById('drawer-close')!;

      function openDrawer() {
        drawerBackdrop.classList.remove('hidden');
        drawer.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        drawer.classList.add('translate-x-full');
        drawerBackdrop.classList.add('hidden');
        document.body.style.overflow = '';
      }

      drawerOpen.addEventListener('click', openDrawer);
      drawerClose.addEventListener('click', closeDrawer);
      drawerBackdrop.addEventListener('click', closeDrawer);

      // Close drawer on nav link click
      drawer.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeDrawer);
      });
    </script>

    <script>
      const toggle = document.getElementById('theme-toggle');
      const toggleMobile = document.getElementById('theme-toggle-mobile');
      const iconSun = document.getElementById('icon-sun');
      const iconMoon = document.getElementById('icon-moon');
      const iconSunMobile = document.getElementById('icon-sun-mobile');
      const iconMoonMobile = document.getElementById('icon-moon-mobile');
      const themeLabel = document.getElementById('theme-label-mobile');

      function applyTheme(theme: string) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('pulse360_theme', theme);
        const isDark = theme === 'dark';
        // Desktop icons
        iconSun?.classList.toggle('hidden', isDark);
        iconMoon?.classList.toggle('hidden', !isDark);
        // Mobile icons
        iconSunMobile?.classList.toggle('hidden', isDark);
        iconMoonMobile?.classList.toggle('hidden', !isDark);
        if (themeLabel) themeLabel.textContent = isDark ? 'Light mode' : 'Dark mode';
      }

      // Init icon state
      const current = document.documentElement.getAttribute('data-theme') ?? 'light';
      applyTheme(current);

      function flipTheme() {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(next);
      }

      toggle?.addEventListener('click', flipTheme);
      toggleMobile?.addEventListener('click', flipTheme);
    </script>

    <!-- Search modal -->
    <div id="search-modal" class="fixed inset-0 z-[100] hidden">
      <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
      <div class="relative max-w-xl mx-auto mt-[15vh] px-6">
        <div class="bg-[var(--color-surface)] rounded-2xl border border-[var(--color-border)] shadow-2xl overflow-hidden">
          <div class="flex items-center gap-3 px-5 border-b border-[var(--color-border)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-muted)] shrink-0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input
              id="search-input"
              type="text"
              placeholder="Search articles…"
              autocomplete="off"
              class="w-full py-4 bg-transparent text-[var(--color-ink)] placeholder:text-[var(--color-muted)] outline-none text-base"
            />
            <kbd class="hidden sm:inline-flex text-[10px] font-medium text-[var(--color-muted)] border border-[var(--color-border)] rounded px-1.5 py-0.5">ESC</kbd>
          </div>
          <div id="search-results" class="max-h-[50vh] overflow-y-auto p-2">
            <p class="px-3 py-6 text-sm text-center text-[var(--color-muted)]">Start typing to search…</p>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Search modal
      import Fuse from 'fuse.js';

      let fuse: Fuse<any> | null = null;
      let searchIndex: any[] = [];
      const modal = document.getElementById('search-modal')!;
      const backdrop = document.getElementById('search-backdrop')!;
      const input = document.getElementById('search-input') as HTMLInputElement;
      const results = document.getElementById('search-results')!;
      const searchToggle = document.getElementById('search-toggle')!;

      async function loadIndex() {
        if (searchIndex.length) return;
        const res = await fetch('/search-index.json');
        searchIndex = await res.json();
        fuse = new Fuse(searchIndex, {
          keys: ['title', 'description', 'category', 'tags'],
          threshold: 0.35,
          limit: 12,
        });
      }

      function openSearch() {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        input.value = '';
        results.innerHTML = '<p class="px-3 py-6 text-sm text-center text-[var(--color-muted)]">Start typing to search…</p>';
        loadIndex();
        setTimeout(() => input.focus(), 50);
      }

      function closeSearch() {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }

      function renderResults(items: any[]) {
        if (!items.length) {
          results.innerHTML = '<p class="px-3 py-6 text-sm text-center text-[var(--color-muted)]">No results found.</p>';
          return;
        }
        results.innerHTML = items
          .map(
            (item) => `
            <a href="/news/${item.slug}" class="flex items-start gap-3 px-3 py-3 rounded-lg hover:bg-[var(--color-accent-soft)] transition-colors group">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors leading-snug">${item.title}</p>
                <p class="text-xs text-[var(--color-muted)] mt-1 line-clamp-1">${item.category} · ${item.description}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-muted)] shrink-0 mt-0.5 opacity-0 group-hover:opacity-100 transition-opacity"><path d="m9 18 6-6-6-6"/></svg>
            </a>`
          )
          .join('');
      }

      const searchToggleMobile = document.getElementById('search-toggle-mobile');
      searchToggle.addEventListener('click', openSearch);
      searchToggleMobile?.addEventListener('click', openSearch);
      backdrop.addEventListener('click', closeSearch);

      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          modal.classList.contains('hidden') ? openSearch() : closeSearch();
        }
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
          closeSearch();
        }
      });

      input.addEventListener('input', () => {
        const q = input.value.trim();
        if (!q) {
          results.innerHTML = '<p class="px-3 py-6 text-sm text-center text-[var(--color-muted)]">Start typing to search…</p>';
          return;
        }
        if (!fuse) return;
        const hits = fuse.search(q).map((r: any) => r.item);
        renderResults(hits);
      });
    </script>

    <script>
      // Bookmark buttons
      const BOOKMARKS_KEY = 'pulse360_bookmarks';

      function getBookmarks(): string[] {
        try { return JSON.parse(localStorage.getItem(BOOKMARKS_KEY) ?? '[]'); }
        catch { return []; }
      }

      function toggleBookmark(slug: string) {
        const bm = getBookmarks();
        const idx = bm.indexOf(slug);
        if (idx >= 0) bm.splice(idx, 1);
        else bm.push(slug);
        localStorage.setItem(BOOKMARKS_KEY, JSON.stringify(bm));
        return idx < 0; // true if now bookmarked
      }

      function syncBookmarkIcons() {
        const bm = new Set(getBookmarks());
        document.querySelectorAll('.bookmark-btn').forEach((btn) => {
          const el = btn as HTMLElement;
          const slug = el.dataset.slug ?? '';
          const svg = el.querySelector('svg')!;
          if (bm.has(slug)) {
            svg.setAttribute('fill', 'currentColor');
            el.classList.add('text-[var(--color-accent)]');
          } else {
            svg.setAttribute('fill', 'none');
            el.classList.remove('text-[var(--color-accent)]');
          }
        });
      }

      document.querySelectorAll('.bookmark-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const el = e.currentTarget as HTMLElement;
          const slug = el.dataset.slug ?? '';
          toggleBookmark(slug);
          syncBookmarkIcons();
        });
      });

      syncBookmarkIcons();
    </script>

    <script>
      // Card share buttons
      document.querySelectorAll('.card-share-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          e.stopPropagation();
          const el = e.currentTarget as HTMLElement;
          const url = el.dataset.url ?? '';
          const title = el.dataset.title ?? '';
          const label = el.querySelector('.card-share-label');
          if (navigator.share) {
            try { await navigator.share({ title, url }); } catch {}
          } else {
            await navigator.clipboard.writeText(url);
            if (label) {
              label.textContent = 'Copied!';
              setTimeout(() => { label.textContent = 'Share'; }, 2000);
            }
          }
        });
      });
    </script>
  </body>
</html>
