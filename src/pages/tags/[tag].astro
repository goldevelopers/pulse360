---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const allArticles = await getCollection('news');
  const tagSet = new Set<string>();
  for (const a of allArticles) {
    for (const tag of a.data.tags ?? []) {
      tagSet.add(tag);
    }
  }
  return Array.from(tagSet).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allArticles = await getCollection('news');
const filtered = allArticles
  .filter((a) => (a.data.tags ?? []).includes(tag!))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title={`Tag: ${tag}`} description={`Articles tagged "${tag}" on pulse360.`}>
  <section class="max-w-6xl mx-auto px-6 pt-14 pb-6">
    <div class="flex items-center gap-4 mb-2">
      <a
        href={`${import.meta.env.BASE_URL}tags`}
        class="inline-flex items-center gap-1 text-sm font-medium uppercase tracking-widest text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        All tags
      </a>
      <div class="w-px h-4 bg-[var(--color-border)]"></div>
      <h1 class="text-xl sm:text-2xl font-bold text-[var(--color-ink)]" style="font-family: var(--font-prose)">
        #{tag}
      </h1>
    </div>
    <p class="text-sm text-[var(--color-muted)] mb-10 opacity-60">
      {filtered.length} article{filtered.length !== 1 ? 's' : ''}
    </p>

    {filtered.length === 0 ? (
      <div class="text-center py-24 text-[var(--color-muted)]">
        <p>No articles with this tag.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filtered.map((article) => (
          <ArticleCard
            id={article.id}
            slug={article.id}
            readingTime={getReadingTime(article.body ?? '')}
            {...article.data}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
